{
    "compilerOptions": {
        "outDir": "bin",
        "target": "es2016",
        "module": "commonjs",
        "moduleResolution": "node",
        "declaration": true,
        "sourceMap": true,
        "stripInternal": true,
        "experimentalDecorators": true,
        "noFallthroughCasesInSwitch": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true
    },
    "files": [
        "index.ts",
        "projectcontour/index.ts",
        "projectcontour/v1/httpproxy.ts",
        "projectcontour/v1/index.ts",
        "projectcontour/v1/tlscertificateDelegation.ts",
        "projectcontour/v1alpha1/contourConfiguration.ts",
        "projectcontour/v1alpha1/contourDeployment.ts",
        "projectcontour/v1alpha1/extensionService.ts",
        "projectcontour/v1alpha1/index.ts",
        "provider.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "utilities.ts"
    ]
}
